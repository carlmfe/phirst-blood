#include <phirst/phirst.hpp>
@USER_INTEGRAND_INCLUDE_LINE@

#include <cstdint>
#include <type_traits>
#include <utility>

namespace {

template <typename T, typename = void>
struct has_raw_evaluate : std::false_type {};

template <typename T>
struct has_raw_evaluate<T, std::void_t<decltype(std::declval<const T&>().evaluate(std::declval<const double (*)[4]>()))>>
    : std::true_type {};

template <typename T, typename = void>
struct has_p4_evaluate : std::false_type {};

template <typename T>
struct has_p4_evaluate<T, std::void_t<decltype(std::declval<const T&>().evaluate(std::declval<const HEPUtils::P4*>()))>>
    : std::true_type {};

template <typename UserIntegrand, int N>
struct PhirstIntegrandAdapter {
    UserIntegrand inner{};

    PHIRST_HOST_DEVICE auto evaluate(const HEPUtils::P4 momenta[]) const -> double {
        if constexpr (has_raw_evaluate<UserIntegrand>::value) {
            double rawMomenta[N][4] = {};
            for (int i = 0; i < N; ++i) {
                rawMomenta[i][0] = momenta[i].E();
                rawMomenta[i][1] = momenta[i].px();
                rawMomenta[i][2] = momenta[i].py();
                rawMomenta[i][3] = momenta[i].pz();
            }
            return inner.evaluate(rawMomenta);
        } else if constexpr (has_p4_evaluate<UserIntegrand>::value) {
            return inner.evaluate(momenta);
        } else {
            static_assert(has_raw_evaluate<UserIntegrand>::value || has_p4_evaluate<UserIntegrand>::value,
                          "Integrand type must define evaluate(const double momenta[][4]) or evaluate(const HEPUtils::P4 momenta[])");
            return 0.0;
        }
    }
};

}  // namespace

extern "C" int phirst_run_integrand(
    double cmEnergy,
    const double* masses,
    int nParticles,
    int64_t nEvents,
    uint64_t seed,
    int useVegas,
    double* mean_out,
    double* error_out)
{
    constexpr int N = @PHIRST_N_PARTICLES@;
    if (nParticles != N) {
        return 1;
    }
    if (masses == nullptr || mean_out == nullptr || error_out == nullptr) {
        return 2;
    }

    try {
        using UserIntegrand = @USER_INTEGRAND_TYPE@;
        using WrappedIntegrand = PhirstIntegrandAdapter<UserIntegrand, N>;

        WrappedIntegrand integrand;
        phirst::RamboIntegrator<WrappedIntegrand, N> runner(nEvents, integrand);

        if (useVegas) {
            runner.runVegas(cmEnergy, masses, *mean_out, *error_out, seed);
        } else {
            runner.run(cmEnergy, masses, *mean_out, *error_out, seed);
        }
        return 0;
    } catch (...) {
        return 3;
    }
}
